{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/run.schema.json",
  "title": "WMB Run",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "current_gate",
    "delivery_level"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "intake",
        "awaiting_research_direction",
        "evidence_and_analysis",
        "result_and_claim_build",
        "manuscript_drafting",
        "independent_review",
        "package_verification",
        "awaiting_final_confirmation",
        "candidate_level_4",
        "downgraded",
        "blocked"
      ]
    },
    "current_gate": {
      "type": "string",
      "minLength": 1
    },
    "delivery_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    }
  },
  "additionalProperties": true
}
