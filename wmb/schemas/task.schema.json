{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/task.schema.json",
  "title": "WMB Agent Task",
  "type": "object",
  "$defs": {
    "taskId": {
      "type": "string",
      "pattern": "^task-[A-Za-z0-9_-]+(?![\\s\\S])"
    },
    "artifactPath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "pattern": "^(?![\\\\/])(?!.*[\\\\:<>\"|?*])(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*(?:^|/)[^/]*[ .](?:/|$))[^\\x00-\\x1f\\r\\n/]+(?:/[^\\x00-\\x1f\\r\\n/]+)*(?![\\s\\S])"
        },
        {
          "not": {
            "pattern": "(?:^|/)(?:[Aa][Uu][Xx]|[Cc][Oo][Nn]|[Nn][Uu][Ll]|[Pp][Rr][Nn]|[Cc][Oo][Mm][1-9¹²³]|[Ll][Pp][Tt][1-9¹²³])[ ]*(?:\\.[^/]*)?(?:/|$)"
          }
        }
      ]
    }
  },
  "required": [
    "task_id",
    "capability",
    "role",
    "context_id",
    "objective",
    "allowed_inputs",
    "required_outputs",
    "acceptance_criteria",
    "prohibited_actions",
    "max_attempts",
    "status"
  ],
  "properties": {
    "task_id": {
      "$ref": "#/$defs/taskId"
    },
    "capability": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*(?![\\s\\S])"
    },
    "role": {
      "enum": [
        "worker",
        "reviewer"
      ]
    },
    "context_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "review_of": {
      "$ref": "#/$defs/taskId"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "allowed_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactPath"
      }
    },
    "required_outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactPath"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibited_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "revoked"
      ]
    },
    "revocation_reason": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "capability": {
            "pattern": "_reviewer$"
          }
        },
        "required": [
          "capability"
        ]
      },
      "then": {
        "required": [
          "review_of"
        ],
        "properties": {
          "role": {
            "const": "reviewer"
          }
        }
      },
      "else": {
        "properties": {
          "role": {
            "const": "worker"
          }
        },
        "not": {
          "required": [
            "review_of"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "revoked"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "revocation_reason"
        ]
      }
    }
  ],
  "additionalProperties": true
}
