{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/task.schema.json",
  "title": "WMB Agent Task",
  "type": "object",
  "required": [
    "task_id",
    "capability",
    "role",
    "context_id",
    "objective",
    "allowed_inputs",
    "required_outputs",
    "acceptance_criteria",
    "prohibited_actions",
    "max_attempts",
    "status"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*(?![\\s\\S])"
    },
    "role": {
      "enum": [
        "worker",
        "reviewer"
      ]
    },
    "context_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "review_of": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "allowed_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibited_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "capability": {
            "pattern": "_reviewer$"
          }
        },
        "required": [
          "capability"
        ]
      },
      "then": {
        "required": [
          "review_of"
        ],
        "properties": {
          "role": {
            "const": "reviewer"
          }
        }
      },
      "else": {
        "properties": {
          "role": {
            "const": "worker"
          }
        },
        "not": {
          "required": [
            "review_of"
          ]
        }
      }
    }
  ],
  "additionalProperties": true
}
