{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/event.schema.json",
  "title": "WMB Event",
  "type": "object",
  "required": [
    "event_id",
    "run_id",
    "timestamp",
    "actor",
    "event_type",
    "from_status",
    "to_status",
    "decision",
    "reason"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "run_id": {
      "type": "string",
      "pattern": "\\S"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "const": "orchestrator"
    },
    "event_type": {
      "const": "transition"
    },
    "from_status": {
      "$ref": "#/$defs/run_status"
    },
    "to_status": {
      "$ref": "#/$defs/run_status"
    },
    "decision": {
      "enum": [
        "PROCEED",
        "REFINE",
        "DOWNGRADE",
        "BLOCK"
      ]
    },
    "reason": {
      "type": "string",
      "pattern": "\\S"
    },
    "task_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "\\S"
      }
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "\\S"
      }
    },
    "artifact_hashes": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "unblock_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "\\S"
      }
    },
    "deliverable": {
      "type": "string",
      "pattern": "\\S"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "BLOCK"
          }
        }
      },
      "then": {
        "required": [
          "unblock_conditions"
        ]
      },
      "else": {
        "not": {
          "required": [
            "unblock_conditions"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "DOWNGRADE"
          }
        }
      },
      "then": {
        "required": [
          "deliverable"
        ]
      },
      "else": {
        "not": {
          "required": [
            "deliverable"
          ]
        }
      }
    }
  ],
  "$defs": {
    "run_status": {
      "enum": [
        "intake",
        "awaiting_research_direction",
        "evidence_and_analysis",
        "result_and_claim_build",
        "manuscript_drafting",
        "independent_review",
        "package_verification",
        "awaiting_final_confirmation",
        "candidate_level_4",
        "downgraded",
        "blocked"
      ]
    }
  },
  "additionalProperties": true
}
