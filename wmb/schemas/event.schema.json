{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/event.schema.json",
  "title": "WMB Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "event_type",
    "from_status",
    "to_status",
    "reason"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "from_status": {
      "type": "string",
      "minLength": 1
    },
    "to_status": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "task_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
