{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/analysis_run.schema.json",
  "title": "WMB Analysis Run",
  "type": "object",
  "required": [
    "analysis_id",
    "status",
    "command",
    "input_hashes",
    "outputs",
    "warnings",
    "errors",
    "exclusions",
    "limitations"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "input_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array"
    },
    "errors": {
      "type": "array"
    },
    "exclusions": {
      "type": "array"
    },
    "limitations": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
