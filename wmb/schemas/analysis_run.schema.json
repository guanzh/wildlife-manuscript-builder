{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wildlife-manuscript-builder.local/schemas/analysis_run.schema.json",
  "title": "WMB Analysis Run",
  "type": "object",
  "required": [
    "analysis_id",
    "status",
    "command",
    "input_hashes",
    "outputs",
    "warnings",
    "errors",
    "exclusions",
    "limitations"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "successful",
        "usable_with_caveat",
        "failed"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "input_hashes": {
      "type": "object",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_item"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_item"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_item"
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_item"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_item"
      }
    }
  },
  "$defs": {
    "trace_item": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": true
}
